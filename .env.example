# Redis Configuration
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Provider Configuration
AI_PROVIDER=gradient
# Options: mock, gradient

# DigitalOcean Gradient Configuration
GRADIENT_ACCESS_TOKEN=your_gradient_access_token_here
GRADIENT_WORKSPACE_ID=your_gradient_workspace_id_here

# DigitalOcean Spaces (Object Storage for Knowledge Base)
DO_SPACES_KEY=your_spaces_key_here
DO_SPACES_SECRET=your_spaces_secret_here
DO_SPACES_BUCKET=aexis-knowledge-base
DO_SPACES_REGION=nyc3

# DigitalOcean Managed Redis (if applicable)
# REDIS_HOST=your-do-redis-host.com

# System Configuration
POD_COUNT=5
STATION_COUNT=21

# Logging Configuration
LOG_LEVEL=INFO
SNAPSHOT_INTERVAL=300

# UI Configuration
UI_HOST=0.0.0.0
UI_PORT=8000
API_PORT=8001
ENABLE_WEB_SERVER=true
